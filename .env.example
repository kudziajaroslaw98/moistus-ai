# Browser clients derive the current hostname in local dev when this points to
# localhost/127.0.0.1 and the app is opened via a LAN URL.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_INTERNAL_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_DEV_PORT=54321
SUPABASE_SERVICE_ROLE=
# Optional overrides for PartyKit JWT verification.
# If left empty, PartyKit derives them from NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
# Optional strict audience check (Supabase user JWTs usually use "authenticated")
SUPABASE_JWT_AUDIENCE=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# PartyKit realtime (Yjs transport)
NEXT_PUBLIC_PARTYKIT_URL='127.0.0.1:1999'
NEXT_PUBLIC_PARTYKIT_DEV_PORT=1999
NEXT_PUBLIC_PARTYKIT_PARTY='main'
PARTYKIT_BASE_URL='http://127.0.0.1:1999'
PARTYKIT_PARTY_NAME='main'
PARTYKIT_ADMIN_TOKEN=

# Development Mode - Bypass subscription limits for local development
# Set to 'true' to disable node/map/AI suggestion limits
NEXT_PUBLIC_DEV_BYPASS_LIMITS=false

# Progressive Web App in development mode
# Default is disabled to avoid stale SW cache/debug issues.
# Set to 'true' only when intentionally testing PWA/offline/push flows locally.
NEXT_PUBLIC_ENABLE_PWA_DEV=false

# WebPush
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=<Public Key>
WEB_PUSH_VAPID_PRIVATE_KEY=<Private Key>
WEB_PUSH_SUBJECT=mailto:you@yourdomain.com
