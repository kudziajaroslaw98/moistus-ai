{
  "name": "shiko",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev --hostname 0.0.0.0",
    "party:dev": "partykit dev",
    "party:deploy": "partykit deploy",
    "party:tail": "partykit tail",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:errors-only": "eslint . --quiet",
    "pretty": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:chromium": "playwright test --project=chromium --project=chromium-serial",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:webkit": "playwright test --project=webkit",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:report": "playwright show-report",
    "e2e:screenshots:pull": "npx tsx e2e/utils/screenshot-sync.ts pull",
    "e2e:screenshots:push": "npx tsx e2e/utils/screenshot-sync.ts push",
    "e2e:screenshots:clear": "npx tsx e2e/utils/screenshot-sync.ts clear",
    "e2e:visual": "pnpm e2e:screenshots:pull && playwright test",
    "e2e:visual:update": "playwright test --update-snapshots && pnpm e2e:screenshots:push"
  },
